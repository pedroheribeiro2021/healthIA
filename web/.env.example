# Público — pode ir para o cliente (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secreto — só em rotas server-side (cron, admin). Nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Secreto — protege GET /api/v1/cron/daily. A Vercel injeta automaticamente
# `Authorization: Bearer $CRON_SECRET` nas chamadas do Vercel Cron quando essa
# env var está configurada no projeto (Settings → Environment Variables).
CRON_SECRET=

# Secreto — AI Engine (POST /api/v1/ai/chat), engines/ai/adapter.ts. Sem a
# chave do provider escolhido, o chat fica indisponível e o resto do app
# funciona normalmente (docs/ENGINES.md). Default: gemini (free tier).
AI_PROVIDER=gemini

# Free tier no Google AI Studio (aistudio.google.com/apikey). GEMINI_MODEL
# tem um default no código (engines/ai/providers/gemini.ts) — sobrescreva
# aqui se o nome do modelo do free tier mudar.
GEMINI_API_KEY=
GEMINI_MODEL=

# Só necessário se AI_PROVIDER=anthropic. Chave em console.anthropic.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Só necessário se AI_PROVIDER=openai. Chave em platform.openai.com.
OPENAI_API_KEY=
OPENAI_MODEL=
